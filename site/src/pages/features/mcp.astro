---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="MCP Server — SessionFS" activeNav="features" description="MCP server lets AI agents search past sessions and read project context.">
<section class="pt-32 pb-20 px-5 noise">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" style="font-family: 'Plus Jakarta Sans';">Your AI remembers</h1>
        <p class="text-lg max-w-xl mx-auto" style="color: #c9d1d9;">The MCP server lets AI agents search your past sessions and read project context during conversations. One command to install.</p>
      </div>

      <div class="term max-w-2xl mx-auto mb-16">
        <div class="term-bar"><div class="term-dot" style="background:#ff5f57"></div><div class="term-dot" style="background:#febc2e"></div><div class="term-dot" style="background:#28c840"></div></div>
        <div class="p-5 text-sm" style="font-family: 'JetBrains Mono', monospace;">
          <div><span style="color:#9ca3af;">$</span> <span style="color:#3ddc84;">sfs mcp install --for claude-code</span></div>
          <div class="mt-2" style="color:#c9d1d9;">MCP server configured for Claude Code.</div>
          <div style="color:#c9d1d9;">Restart Claude Code to activate.</div>
          <div class="mt-4" style="color:#9ca3af;">Tools available to your AI agent:</div>
          <div class="mt-1" style="color:#e6edf3;">&bull; search_sessions — Search past sessions by keyword</div>
          <div style="color:#e6edf3;">&bull; get_session_context — Load full conversation from a past session</div>
          <div style="color:#e6edf3;">&bull; list_recent_sessions — Browse recent work</div>
          <div style="color:#e6edf3;">&bull; find_related_sessions — Find sessions for a file or error</div>
          <div style="color:#e6edf3;">&bull; get_project_context — Read shared team conventions</div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="glass p-6">
          <h3 class="font-semibold mb-2">One-command install</h3>
          <p class="text-sm" style="color: #c9d1d9;">Works with Claude Code, Cursor, and Copilot. Adds SessionFS to your tool's MCP config automatically.</p>
        </div>
        <div class="glass p-6">
          <h3 class="font-semibold mb-2">Project context</h3>
          <p class="text-sm" style="color: #c9d1d9;">Share architecture decisions, conventions, and API contracts with every AI agent on your team. One document per repo.</p>
        </div>
        <div class="glass p-6">
          <h3 class="font-semibold mb-2">Local + Remote</h3>
          <p class="text-sm" style="color: #c9d1d9;">Local MCP server on stdio for desktop tools. Remote HTTP/SSE server for cloud-connected AI tools.</p>
        </div>
      </div>

      <div class="text-center mt-12">
        <a href="/mcp/" class="inline-flex items-center gap-2 font-semibold rounded-lg px-6 py-3 text-white hover:brightness-110 transition" style="background: #4f9cf7;">Read the MCP docs</a>
      </div>
    </div>
  </section>
</BaseLayout>

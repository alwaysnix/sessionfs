{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sessionfs.dev/schemas/workspace.schema.json",
  "title": "SFS Workspace",
  "description": "Workspace context for a .sfs session: git state, relevant files, and environment. Captures enough to reproduce the workspace conditions at session time.",
  "type": "object",
  "required": ["root_path"],
  "additionalProperties": false,
  "properties": {
    "root_path": {
      "type": "string",
      "description": "Absolute path to the workspace root directory at capture time. All relative paths in the session are relative to this.",
      "examples": ["/Users/ola/Documents/Repo/sessionfs"]
    },
    "git": {
      "$ref": "#/$defs/git_context",
      "description": "Git repository state at session time. Null if the workspace is not a git repo."
    },
    "files": {
      "type": "array",
      "description": "Relevant files referenced during the session. Populated by the converter from tool call analysis.",
      "items": {
        "$ref": "#/$defs/file_ref"
      },
      "default": []
    },
    "environment": {
      "$ref": "#/$defs/environment_info",
      "description": "Runtime environment details."
    },
    "metadata": {
      "type": "object",
      "description": "Extensible key-value pairs.",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "git_context": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "default": null,
      "properties": {
        "remote_url": {
          "type": ["string", "null"],
          "description": "Git remote origin URL.",
          "examples": ["https://github.com/user/repo.git"],
          "default": null
        },
        "branch": {
          "type": ["string", "null"],
          "description": "Active branch name.",
          "examples": ["main", "feature/auth"],
          "default": null
        },
        "commit_sha": {
          "type": ["string", "null"],
          "description": "HEAD commit SHA at session start.",
          "examples": ["a1b2c3d4e5f6a1b2c3d4e5f6a1b2c3d4e5f6a1b2"],
          "default": null
        },
        "commit_message": {
          "type": ["string", "null"],
          "description": "HEAD commit message (first line).",
          "default": null
        },
        "dirty": {
          "type": "boolean",
          "description": "True if the working tree had uncommitted changes at session start.",
          "default": false
        },
        "diff_path": {
          "type": ["string", "null"],
          "description": "Relative path (within .sfs directory) to a unified diff file capturing uncommitted changes. Only present when dirty is true.",
          "default": null
        }
      }
    },
    "file_ref": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Workspace-relative file path.",
          "examples": ["src/main.py", "README.md"]
        },
        "sha256": {
          "type": ["string", "null"],
          "description": "SHA-256 hash of the file contents at capture time. For validation on pull.",
          "default": null
        },
        "size_bytes": {
          "type": ["integer", "null"],
          "description": "File size in bytes.",
          "minimum": 0,
          "default": null
        },
        "last_modified": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "File modification time.",
          "default": null
        },
        "role": {
          "type": "string",
          "description": "How this file was involved in the session.",
          "enum": ["read", "written", "edited", "created", "deleted", "referenced"],
          "default": "referenced"
        }
      }
    },
    "environment_info": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "default": null,
      "properties": {
        "os": {
          "type": ["string", "null"],
          "description": "Operating system identifier.",
          "examples": ["darwin", "linux", "windows"],
          "default": null
        },
        "os_version": {
          "type": ["string", "null"],
          "description": "OS version string.",
          "examples": ["Darwin 23.6.0"],
          "default": null
        },
        "shell": {
          "type": ["string", "null"],
          "description": "Default shell.",
          "examples": ["bash", "zsh", "fish"],
          "default": null
        },
        "languages": {
          "type": "object",
          "description": "Programming language runtimes detected. Keys are language names, values are version strings.",
          "additionalProperties": { "type": "string" },
          "default": {},
          "examples": [{"python": "3.12.1", "node": "20.11.0"}]
        },
        "venv_path": {
          "type": ["string", "null"],
          "description": "Path to active virtual environment, relative to workspace root.",
          "default": null
        }
      }
    }
  }
}

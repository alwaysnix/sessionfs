{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sessionfs.dev/schemas/tools.schema.json",
  "title": "SFS Tools",
  "description": "Tool configurations available during a .sfs session: MCP servers, shell tools, and custom functions.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mcp_servers": {
      "type": "array",
      "description": "MCP (Model Context Protocol) servers connected during the session.",
      "items": {
        "$ref": "#/$defs/mcp_server"
      },
      "default": []
    },
    "shell": {
      "$ref": "#/$defs/shell_config",
      "description": "Shell/command execution configuration."
    },
    "custom_tools": {
      "type": "array",
      "description": "Custom function/tool definitions available during the session.",
      "items": {
        "$ref": "#/$defs/custom_tool"
      },
      "default": []
    },
    "tools_used": {
      "type": "array",
      "description": "Names of tools actually invoked during the session (for quick reference without parsing messages).",
      "items": { "type": "string" },
      "default": [],
      "examples": [["Read", "Write", "Bash", "Glob"]]
    },
    "metadata": {
      "type": "object",
      "description": "Extensible key-value pairs.",
      "additionalProperties": true,
      "default": {}
    }
  },
  "$defs": {
    "mcp_server": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Server name.",
          "examples": ["filesystem", "github", "postgres"]
        },
        "uri": {
          "type": ["string", "null"],
          "description": "Server connection URI (with credentials redacted).",
          "examples": ["stdio://mcp-server-filesystem"],
          "default": null
        },
        "transport": {
          "type": ["string", "null"],
          "description": "Transport protocol.",
          "enum": ["stdio", "sse", "http", null],
          "default": null
        },
        "tools_provided": {
          "type": "array",
          "description": "Names of tools this server provides.",
          "items": { "type": "string" },
          "default": []
        },
        "auth_ref": {
          "type": ["string", "null"],
          "description": "Reference to auth configuration (NOT the actual credential). E.g., 'env:GITHUB_TOKEN'.",
          "default": null
        }
      }
    },
    "shell_config": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "default": null,
      "properties": {
        "default_shell": {
          "type": ["string", "null"],
          "description": "Default shell used for command execution.",
          "examples": ["bash", "zsh"],
          "default": null
        },
        "working_directory": {
          "type": ["string", "null"],
          "description": "Default working directory for shell commands.",
          "default": null
        },
        "sandbox_policy": {
          "type": ["string", "null"],
          "description": "Sandbox restrictions on shell execution.",
          "examples": ["read-only", "unrestricted"],
          "default": null
        },
        "approval_policy": {
          "type": ["string", "null"],
          "description": "Whether shell commands require user approval.",
          "examples": ["never", "on-request", "always"],
          "default": null
        }
      }
    },
    "custom_tool": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name.",
          "examples": ["deploy", "run_tests"]
        },
        "description": {
          "type": ["string", "null"],
          "description": "Human-readable description of what the tool does.",
          "default": null
        },
        "parameters_schema": {
          "type": ["object", "null"],
          "description": "JSON Schema describing the tool's input parameters.",
          "default": null
        },
        "source": {
          "type": ["string", "null"],
          "description": "Where this tool definition came from.",
          "examples": ["mcp:filesystem", "builtin", "skill:openai-docs"],
          "default": null
        }
      }
    }
  }
}
